# =============================================================================
# Influencer Intel 环境变量
# 复制为 .env 后按需修改：cp .env.example .env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=influencer
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=influencer_intel
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Backend API ---
# Docker Compose 内使用 postgres 主机名：
DATABASE_URL=postgresql+asyncpg://influencer:CHANGE_ME_STRONG_PASSWORD@postgres:5432/influencer_intel
# 本地直连 PostgreSQL 时改为（示例）：
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/influencer_intel

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Docker 启动 API 时是否自动执行 seed（仅空库时写入，已有数据会跳过）
RUN_SEED=false

# --- SMTP 邮件（留空则发信接口返回友好提示，不会崩溃）---
# 腾讯企业邮箱：需在邮箱后台开启 SMTP，SMTP_PASSWORD 填「客户端专用密码/授权码」（不是网页登录密码）。
# 465 端口用 SSL（SMTP_USE_TLS=true）；587 端口用 STARTTLS。
SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_USER=amazon03@ptraveldesign.com
SMTP_PASSWORD=
SMTP_FROM=amazon03@ptraveldesign.com
SMTP_FROM_NAME=
SMTP_USE_TLS=true

# AI 定制邮件发送队列：每日手动发送上限（保守默认 20）
OUTREACH_DAILY_SEND_LIMIT=20

# --- 收信（IMAP 轮询 / inbound webhook）---
INBOUND_EMAIL_ADDRESS=
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_USE_SSL=true
IMAP_FOLDER=INBOX
IMAP_POLL_ENABLED=false
IMAP_POLL_INTERVAL_MINUTES=5
EMAIL_INBOUND_WEBHOOK_SECRET=

# --- AI 分析（OpenAI / ChatGPT，推荐）---
# 未配置 OPENAI_API_KEY 时 AI 推荐/分析接口返回明确错误或使用本地启发式评分
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_API_BASE=https://code.codingplay.top/v1

# --- 知识库 ScandiHome 服务器端导入路径（供页面一键导入）---
SCANDIHOME_PDF_PATH=
SCANDIHOME_PPTX_PATH=

# --- 采集器模式：apify | auto（mock 已关闭，仅真实 API）---
COLLECTOR_MODE=apify
# Instagram 数据源：apify（推荐）| api_direct | hikerapi | yepapi
INSTAGRAM_DATA_PROVIDER=apify
# YouTube 数据源：apify（推荐，避免 API Direct 429）| api_direct
YOUTUBE_DATA_PROVIDER=apify
# TikTok 数据源：apify（推荐）| api_direct
TIKTOK_DATA_PROVIDER=apify
# Facebook 数据源：apify（推荐）| api_direct
FACEBOOK_DATA_PROVIDER=apify

# --- Collection task performance / recovery ---
COLLECTION_MAX_RUNNING_TASKS=1
COLLECTION_PROFILE_ENRICH_CONCURRENCY=2
COLLECTION_CONTACT_CONCURRENCY=2
COLLECTION_AI_CONCURRENCY=1
COLLECTION_PROFILE_REQUEST_TIMEOUT_SECONDS=20
COLLECTION_RUNNING_STALE_SECONDS=180
# 等价别名（与 COLLECTION_RUNNING_STALE_SECONDS 相同语义）：
# COLLECTION_TASK_STALE_AFTER_SECONDS=180

# --- API Direct（Facebook；Instagram / YouTube / TikTok 可选 api_direct 模式）---
API_DIRECT_API_KEY=
API_DIRECT_API_BASE=https://apidirect.io
API_DIRECT_TIMEOUT_SECONDS=120
API_DIRECT_MAX_REQUESTS_PER_PLATFORM=20
API_DIRECT_MAX_PAGES_PER_REQUEST=1
API_DIRECT_TIKTOK_DEFAULT_PAGES=1

# --- Instagram 采集（Apify，可选：评论/相似账号等）---
APIFY_TOKEN=

# Instagram 主页采集 Actor（Apify Store: logical_scrapers/instagram-profile-scraper）
APIFY_INSTAGRAM_ACTOR_ID=logical_scrapers~instagram-profile-scraper
# Instagram 主页补采 fallback Actor（Apify Store: coderx/instagram-profile-scraper-api）
APIFY_INSTAGRAM_PROFILE_FALLBACK_ENABLED=true
APIFY_INSTAGRAM_PROFILE_FALLBACK_ACTOR_ID=coderx~instagram-profile-scraper-api
# Hashtag 发现（Apify Store: apify/instagram-hashtag-scraper）
APIFY_INSTAGRAM_HASHTAG_ACTOR_ID=apify~instagram-hashtag-scraper
APIFY_INSTAGRAM_RELATED_ACTOR_ID=
# 评论区采集（Apify Store: apify/instagram-comment-scraper）
APIFY_INSTAGRAM_COMMENT_ACTOR_ID=apify~instagram-comment-scraper
APIFY_INSTAGRAM_POST_ACTOR_ID=apify~instagram-post-scraper
# YouTube 关键词/频道发现（Apify Store: streamers/youtube-scraper）
APIFY_YOUTUBE_ACTOR_ID=streamers~youtube-scraper
APIFY_YOUTUBE_EMAIL_ACTOR_ID=dataovercoffee/Youtube-Channel-Business-Email-Scraper
# YouTube Apify 超时：streamers/youtube-scraper 单关键词通常 40~90 秒
APIFY_YOUTUBE_TIMEOUT_SECONDS=90
APIFY_YOUTUBE_MAX_RETRIES=1
YOUTUBE_DISCOVERY_KEYWORD_TIMEOUT_SECONDS=90
YOUTUBE_DISCOVERY_SLOW_THRESHOLD_SECONDS=45
YOUTUBE_DISCOVERY_MAX_DURATION_SECONDS=300

# Amazon competitor_product 采集加速（任务/平台/关键词超时与关键词上限）
COMPETITOR_PRODUCT_TASK_TIMEOUT_SECONDS=300
COMPETITOR_PRODUCT_PLATFORM_TIMEOUT_SECONDS=90
COMPETITOR_PRODUCT_KEYWORD_TIMEOUT_SECONDS=25
COMPETITOR_PRODUCT_MAX_SEARCH_KEYWORDS=8
COMPETITOR_PRODUCT_MAX_HASHTAGS=6
# 关键词并发 2~3，过高易触发 Apify 限流
YOUTUBE_APIFY_KEYWORD_CONCURRENCY=1
# TikTok 关键词/hashtag 发现（Apify Store: clockworks/tiktok-scraper）
APIFY_TIKTOK_ACTOR_ID=clockworks~tiktok-scraper
APIFY_TIKTOK_SCRAPER_ACTOR_ID=clockworks/tiktok-scraper
APIFY_TIKTOK_PROFILE_ACTOR_ID=clockworks/tiktok-profile-scraper
APIFY_TIKTOK_VIDEO_ACTOR_ID=clockworks/tiktok-video-scraper
APIFY_TIKTOK_HASHTAG_ACTOR_ID=clockworks/tiktok-hashtag-scraper
APIFY_TIKTOK_FALLBACK_ACTOR_ID=clockworks/free-tiktok-scraper
TIKTOK_APIFY_KEYWORD_CONCURRENCY=1
# Facebook 关键词 Page 搜索（Apify Store: parseforge/facebook-search-scraper）
APIFY_FACEBOOK_SEARCH_ACTOR_ID=parseforge~facebook-search-scraper
# Facebook Page URL 导入（Apify Store: apify/facebook-pages-scraper）
APIFY_FACEBOOK_PAGES_ACTOR_ID=apify/facebook-pages-scraper
# Facebook 内容 URL 作者发现（Apify Store）
APIFY_FACEBOOK_POSTS_ACTOR_ID=apify/facebook-posts-scraper
APIFY_FACEBOOK_COMMENTS_ACTOR_ID=apify/facebook-comments-scraper
APIFY_FACEBOOK_REELS_ACTOR_ID=apify/facebook-reels-scraper
# Facebook Apify：关键词搜索 + 主页补采（单主页超时后跳过，不阻塞整批）
APIFY_FACEBOOK_TIMEOUT_SECONDS=90
FACEBOOK_DISCOVERY_KEYWORD_TIMEOUT_SECONDS=90
FACEBOOK_APIFY_PROFILE_TIMEOUT_SECONDS=90
FACEBOOK_DISCOVERY_SLOW_THRESHOLD_SECONDS=45
FACEBOOK_DISCOVERY_MAX_DURATION_SECONDS=300
FACEBOOK_APIFY_KEYWORD_CONCURRENCY=1
FACEBOOK_APIFY_PROFILE_CONCURRENCY=1
APIFY_TIMEOUT_SECONDS=180
# HikerAPI / YepAPI（可选，未配置时请保持 INSTAGRAM_DATA_PROVIDER=apify）
HIKERAPI_API_KEY=
HIKERAPI_BASE_URL=https://api.hikerapi.com
YEPAPI_API_KEY=
YEPAPI_BASE_URL=https://api.yepapi.com
INSTAGRAM_PROVIDER_TIMEOUT_SECONDS=120

# --- Outreach sync ---
# Mailchimp server prefix can be left empty when the API key ends with "-usX".
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=
MAILCHIMP_LIST_ID=
MAILCHIMP_STATUS_IF_NEW=pending
MAILCHIMP_TIMEOUT_SECONDS=30

# Klaviyo audience sync. This is not SMTP; direct sending needs a Klaviyo send provider/flow.
KLAVIYO_API_KEY=
KLAVIYO_LIST_ID=
KLAVIYO_TIMEOUT_SECONDS=30

# --- Frontend ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=/api-proxy
# Next.js 服务端代理目标（apps/web/.env.local 同样配置）
INTERNAL_API_URL=http://127.0.0.1:8000

# --- Local backup ---
# Optional. Defaults to ./backups when empty.
BACKUP_DIR=
