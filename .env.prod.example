# 复制为 .env.prod 后填写（勿提交仓库）

# --- OpenAI 兼容接口（默认；经中转站）---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://code.codingplay.top/redeem
OPENAI_MODEL=gpt-5.5
LLM_PROVIDER=openai_compatible

# --- 备选：Moonshot / Kimi ---
# LLM_PROVIDER=moonshot
# MOONSHOT_API_KEY=
# KIMI_API_KEY=
# KIMI_MODEL=kimi-k2.6
# KIMI_BASE_URL=https://api.moonshot.ai/v1

# 对外监听（云服务器必填）
QUOTE_SERVER_HOST=0.0.0.0
QUOTE_ADMIN_SERVER_HOST=0.0.0.0
QUOTE_SERVER_PORT=8776
QUOTE_ADMIN_HTTP_PORT=8080

# 后台登录
QUOTE_ADMIN_USERNAME=admin
QUOTE_ADMIN_PASSWORD=改成强密码
QUOTE_ADMIN_SECRET=随机长字符串

# 报价入库 + 知识回流（前台报价 -> data/quotes.db；miss 候选 -> pending -> 可选自动写入 price_kb）
KNOWLEDGE_AUTO_LEARN=1
KNOWLEDGE_AUTO_WRITE=0
KNOWLEDGE_PENDING_AUTO_APPLY=1
KNOWLEDGE_AUTO_LEARN_MIN_CONFIDENCE=0.8

# 磁盘紧张时用 CPU 版 torch（省 CUDA 大包）
QUOTE_DEPLOY_CPU_TORCH=1
